generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  supabaseUserId String         @unique // Supabase auth.users UUID
  email          String         @unique
  displayName    String?
  role           String         @default("customer") // "admin" | "customer"
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  profile        UserProfile?
  benchmarks     Benchmark[]
  styleProfiles  StyleProfile[]
  generations    Generation[]
}

model UserProfile {
  id          Int      @id @default(autoincrement())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  worldview   String?
  audience    String?
  experiences String?
  toneRules   String?
  ngWords     String?
  updatedAt   DateTime @updatedAt
}

model Benchmark {
  id        Int       @id @default(autoincrement())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  url       String?
  text      String
  likes     Int       @default(0)
  reposts   Int       @default(0)
  replies   Int       @default(0)
  quotes    Int       @default(0)
  score     Float     @default(0)
  postedAt  DateTime?
  createdAt DateTime  @default(now())
}

model StyleProfile {
  id            Int      @id @default(autoincrement())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  hookType      String
  structureType String
  toneFeatures  String
  avgLength     Int
  createdAt     DateTime @default(now())
}

model Generation {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  theme     String
  claim     String
  episode   String?
  target    String?
  tone      String
  ngWords   String?
  drafts    Draft[]
  createdAt DateTime @default(now())
}

model Draft {
  id              Int        @id @default(autoincrement())
  generationId    Int
  generation      Generation @relation(fields: [generationId], references: [id])
  text            String
  charCount       Int
  intent          String
  hook            String
  structure       String
  takeaways       String
  ngCaution       String?
  summary         String
  tags            String
  similarityScore Float
  riskFlags       String
  adopted         Boolean    @default(false)
  createdAt       DateTime   @default(now())
}
